# =============================================================================
# MINTA a REST Client (.http) tesztekhez  ->  masold at .env nevre es toltsd ki.
#   Copy-Item .env.example .env
# A valodi .env gitignore-olt (titok soha nem kerul verziokovetesbe).
# Alternativa: ha a .env.crm-dev mar ki van toltve, abbol is masolhatsz:
#   Copy-Item .env.crm-dev .env
#
# Ezeket a kulcsokat olvassak a .http fajlok a {{$dotenv ...}} hivatkozasokkal.
# Rendszer: CRM DEV (DHC) - ZPORTAL_SRV / ZEPT_GW / DHCK901206
# =============================================================================

# SAP host URL. FONTOS: a vegen legyen '/' (a .http path ehhez fuzodik).
SAP_URL=https://<host>:<port>/

# Bejelentkezesi kliens (mandant).
SAP_CLIENT=100

# SAP felhasznalonev.
SAP_USERNAME=<sap-user>

# SAP jelszo. Csak a lokalis .env-be kerul, ide (mintaba) SOHA ne ird be.
SAP_PASSWORD=
